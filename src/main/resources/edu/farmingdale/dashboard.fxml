<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="table-scroll"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.farmingdale.DashboardController">

    <VBox styleClass="main-content" spacing="0">

        <Label text="Dashboard" styleClass="page-title">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </Label>

        <!-- Stat Cards Row -->
        <HBox spacing="20">
            <VBox.margin><Insets bottom="25"/></VBox.margin>

            <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                <HBox alignment="CENTER_LEFT">
                    <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                        <image><Image url="@/images/dollar.png"/></image>
                    </ImageView>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="totalRevenueLabel" text="\$0.00" styleClass="stat-value"/>
                <Label text="Total Revenue" styleClass="stat-subtitle"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                <HBox alignment="CENTER_LEFT">
                    <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                        <image><Image url="@/images/shopping-cart.png"/></image>
                    </ImageView>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="unprocessedOrdersLabel" text="0" styleClass="stat-value"/>
                <Label text="Unprocessed Orders" styleClass="stat-subtitle"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                <HBox alignment="CENTER_LEFT">
                    <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                        <image><Image url="@/images/box.png"/></image>
                    </ImageView>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="upcomingShipmentsLabel" text="0" styleClass="stat-value"/>
                <Label text="Upcoming Shipments" styleClass="stat-subtitle"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                <HBox alignment="CENTER_LEFT">
                    <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                        <image><Image url="@/images/delivery.png"/></image>
                    </ImageView>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="lowStockCountLabel" text="0" styleClass="stat-value"/>
                <Label text="Low Stock Alerts" styleClass="stat-subtitle"/>
            </VBox>

        </HBox>

        <!-- Low Stock Items + Upcoming Shipments -->
        <HBox spacing="20">
            <VBox.margin><Insets bottom="25"/></VBox.margin>

            <VBox HBox.hgrow="ALWAYS" styleClass="section-card">
                <Label text="Low Stock Items" styleClass="section-title">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </Label>
                <HBox styleClass="table-header-row">
                    <Label text="Product"  styleClass="table-header-cell" prefWidth="200"/>
                    <Label text="On Hand"  styleClass="table-header-cell" prefWidth="100"/>
                    <Label text="Minimum"  styleClass="table-header-cell" prefWidth="100"/>
                </HBox>
                <VBox fx:id="lowStockRows"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" styleClass="section-card">
                <Label text="Upcoming Shipments" styleClass="section-title">
                    <VBox.margin><Insets bottom="12"/></VBox.margin>
                </Label>
                <HBox styleClass="table-header-row">
                    <Label text="Supplier"  styleClass="table-header-cell" prefWidth="160"/>
                    <Label text="Product"   styleClass="table-header-cell" prefWidth="160"/>
                    <Label text="Due Date"  styleClass="table-header-cell" prefWidth="100"/>
                </HBox>
                <VBox fx:id="shipmentRows"/>
            </VBox>

        </HBox>

        <!-- Top Selling Product -->
        <VBox styleClass="section-card">
            <Label text="Top Selling Product" styleClass="section-title">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </Label>
            <Label fx:id="topProductLabel" text="-" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="topProductSalesLabel" text="" styleClass="stat-subtitle"/>
        </VBox>

    </VBox>

</ScrollPane>
