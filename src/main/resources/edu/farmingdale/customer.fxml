<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.farmingdale.CustomerController"
      styleClass="main-content">

    <!-- Title Row -->
    <HBox alignment="CENTER_LEFT">
        <VBox.margin><Insets bottom="20"/></VBox.margin>
        <Label text="Customer Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Add Customer" styleClass="btn-primary" onAction="#onAddCustomer"/>
    </HBox>

    <!-- Stat Cards Row -->
    <HBox spacing="20">
        <VBox.margin><Insets bottom="25"/></VBox.margin>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <HBox alignment="CENTER_LEFT">
                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                    <image><Image url="@/images/user.png"/></image>
                </ImageView>
            </HBox>
            <Label fx:id="totalCustomersLabel" text="0" styleClass="stat-value"/>
            <Label text="Total Customers" styleClass="stat-subtitle"/>
        </VBox>

    </HBox>

    <!-- Add Customer Form (hidden by default) -->
    <VBox fx:id="addCustomerForm" styleClass="section-card" visible="false" managed="false">
        <VBox.margin><Insets bottom="20"/></VBox.margin>
        <Label text="Add New Customer" styleClass="section-title">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
        </Label>
        <HBox spacing="20">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
            <TextField fx:id="firstNameField" promptText="First Name" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
            <TextField fx:id="lastNameField"  promptText="Last Name"  maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
        </HBox>
        <HBox spacing="20">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
            <TextField fx:id="emailField" promptText="Email"        maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
            <TextField fx:id="phoneField" promptText="Phone Number" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
        </HBox>
        <HBox spacing="12">
            <Button text="Save Customer" styleClass="btn-primary"   onAction="#onSaveCustomer"/>
            <Button text="Cancel"        styleClass="btn-secondary" onAction="#onCancelCustomer"/>
        </HBox>
    </VBox>

    <!-- Search Bar -->
    <HBox styleClass="search-bar">
        <VBox.margin><Insets bottom="15"/></VBox.margin>
        <TextField fx:id="searchField"
                   promptText="Search customers by name, email, or ID..."
                   maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="search-field"/>
    </HBox>

    <!-- Customer Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="section-card">
        <HBox styleClass="table-header-row">
            <Label text="Profile ID" styleClass="table-header-cell" prefWidth="100"/>
            <Label text="Full Name"  styleClass="table-header-cell" prefWidth="200"/>
            <Label text="Email"      styleClass="table-header-cell" prefWidth="220"/>
            <Label text="Phone"      styleClass="table-header-cell" prefWidth="140"/>
            <Label text="Actions"    styleClass="table-header-cell" prefWidth="80"/>
        </HBox>

        <!-- Template row — cloned by CustomerController for each customer -->
        <HBox fx:id="templateRow" styleClass="table-row" visible="false" managed="false">
            <Label text="CST-001"      styleClass="table-cell" prefWidth="100"/>
            <Label text="Sample Name"  styleClass="table-cell" prefWidth="200"/>
            <Label text="email@ex.com" styleClass="table-cell" prefWidth="220"/>
            <Label text="555-0000"     styleClass="table-cell" prefWidth="140"/>
            <Label text=""             styleClass="table-cell" prefWidth="80"/>
        </HBox>

        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="table-scroll">
            <VBox fx:id="customerRows"/>
        </ScrollPane>
    </VBox>

</VBox>
