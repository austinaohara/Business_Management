<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.farmingdale.SupplierController"
      styleClass="main-content">

    <!-- Title Row -->
    <HBox alignment="CENTER_LEFT">
        <VBox.margin><Insets bottom="20"/></VBox.margin>
        <Label text="Supplier Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ New Order Request" styleClass="btn-primary" onAction="#onNewOrderRequest"/>
    </HBox>

    <!-- Stat Cards Row -->
    <HBox spacing="20">
        <VBox.margin><Insets bottom="25"/></VBox.margin>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                    <image><Image url="@/images/delivery.png"/></image>
                </ImageView>
                <Label text="Active Suppliers" styleClass="stat-subtitle"/>
            </HBox>
            <Label text="1" styleClass="stat-value"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                    <image><Image url="@/images/shopping-cart.png"/></image>
                </ImageView>
                <Label text="Active Orders" styleClass="stat-subtitle"/>
            </HBox>
            <Label text="3" styleClass="stat-value"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                    <image><Image url="@/images/calendar.png"/></image>
                </ImageView>
                <Label text="Next Delivery" styleClass="stat-subtitle"/>
            </HBox>
            <Label text="Apr 30, 2026" styleClass="stat-date"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                    <image><Image url="@/images/clock.png"/></image>
                </ImageView>
                <Label text="In Transit" styleClass="stat-subtitle"/>
            </HBox>
            <Label text="1" styleClass="stat-value-warning"/>
        </VBox>

    </HBox>

    <!-- New Order Request Form (hidden by default) -->
    <VBox fx:id="newOrderForm" styleClass="section-card" visible="false" managed="false">
        <VBox.margin><Insets bottom="20"/></VBox.margin>
        <Label text="New Order Request" styleClass="section-title">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
        </Label>

        <HBox spacing="20">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
            <TextField fx:id="supplierNameField" promptText="Supplier Name" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
            <TextField fx:id="productNameField"  promptText="Product Name"  maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
        </HBox>

        <HBox spacing="20">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
            <TextField fx:id="quantityField" promptText="Quantity"   maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
            <TextField fx:id="dueDateField"  promptText="mm/dd/yyyy" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
        </HBox>

        <HBox spacing="20">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
            <TextField fx:id="priorityField" promptText="Priority (1-10, 10 = highest)" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="form-field"/>
        </HBox>

        <TextArea fx:id="notesArea" promptText="Additional notes or requirements..."
                  styleClass="form-textarea" wrapText="true" prefHeight="100">
            <VBox.margin><Insets bottom="20"/></VBox.margin>
        </TextArea>

        <HBox spacing="12">
            <Button text="Submit Request" styleClass="btn-primary" onAction="#onSubmitOrder"/>
            <Button text="Cancel"         styleClass="btn-secondary" onAction="#onCancelOrder"/>
        </HBox>
    </VBox>

    <!-- Search Bar -->
    <HBox styleClass="search-bar">
        <VBox.margin><Insets bottom="15"/></VBox.margin>
        <TextField promptText="Search orders by supplier, product, or status..."
                   maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="search-field"/>
    </HBox>

    <!-- Upcoming Deliveries -->
    <VBox VBox.vgrow="ALWAYS" styleClass="section-card">
        <VBox.margin><Insets bottom="20"/></VBox.margin>

        <Label text="Upcoming Deliveries" styleClass="section-title">
            <VBox.margin><Insets bottom="15"/></VBox.margin>
        </Label>

        <HBox styleClass="table-header-row">
            <Label text="Supplier"     styleClass="table-header-cell" prefWidth="120"/>
            <Label text="Product"      styleClass="table-header-cell" prefWidth="120"/>
            <Label text="Qty"          styleClass="table-header-cell" prefWidth="50"/>
            <Label text="Due Date"     styleClass="table-header-cell" prefWidth="95"/>
            <Label text="Priority"     styleClass="table-header-cell" prefWidth="55"/>
            <Label text="Notes"        styleClass="table-header-cell" prefWidth="120"/>
            <Label text="Status"       styleClass="table-header-cell" prefWidth="90"/>
            <Label text="Confirm"      styleClass="table-header-cell" prefWidth="95"/>
        </HBox>

        <!-- Template row — cloned and populated when data is inserted -->
        <HBox fx:id="deliveryTemplateRow" styleClass="table-row" alignment="CENTER_LEFT"
              visible="false" managed="false">
            <Label text="TechCorp"     styleClass="table-cell" prefWidth="150"/>
            <Label text="Laptops"      styleClass="table-cell" prefWidth="150"/>
            <Label text="25"           styleClass="table-cell" prefWidth="70"/>
            <Label text="05/01/2026"   styleClass="table-cell" prefWidth="110"/>
            <Label text="8"            styleClass="table-cell" prefWidth="80"/>
            <Label text="—"            styleClass="table-cell" prefWidth="170"/>
            <Label text="In Transit"   styleClass="status-in-transit"/>
        </HBox>

        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" maxHeight="220" styleClass="table-scroll">
            <VBox fx:id="deliveryRows"/>
        </ScrollPane>

    </VBox>

</VBox>
