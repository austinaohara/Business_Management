<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.farmingdale.RegistrationController"
            prefWidth="1200"
            prefHeight="750"
            styleClass="auth-root">

    <center>
        <StackPane maxWidth="1040" maxHeight="680" styleClass="auth-stage">
            <Region styleClass="auth-glow-one"/>
            <Region styleClass="auth-glow-two"/>

            <HBox maxWidth="960" styleClass="auth-shell">
                <VBox prefWidth="330" styleClass="auth-side">
                    <Label text="Business Management" styleClass="auth-side-brand"/>
                    <Label text="Join the workspace today." wrapText="true" styleClass="auth-side-title">
                        <VBox.margin><Insets top="18"/></VBox.margin>
                    </Label>
                    <Label text="Create your account to access inventory, suppliers, customers, and sales from one clean operational workspace." wrapText="true" styleClass="auth-side-subtitle">
                        <VBox.margin><Insets top="10" bottom="24"/></VBox.margin>
                    </Label>

                    <VBox spacing="12">
                        <Label text="Live operational dashboard" styleClass="auth-side-item"/>
                        <Label text="Product and supplier workflows" styleClass="auth-side-item"/>
                        <Label text="Reliable Derby persistence" styleClass="auth-side-item"/>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label text="Operational Suite v1" styleClass="auth-side-foot"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" styleClass="auth-form-panel">
                    <BorderPane>
                        <left>
                            <Label text="New Account" styleClass="auth-badge"/>
                        </left>
                        <right>
                            <Label text="Staff Portal" styleClass="auth-caption"/>
                        </right>
                    </BorderPane>

                    <Label text="Create Account" styleClass="auth-title">
                        <VBox.margin><Insets top="12"/></VBox.margin>
                    </Label>
                    <Label text="Set up your credentials to access the workspace." styleClass="auth-subtitle">
                        <VBox.margin><Insets bottom="20"/></VBox.margin>
                    </Label>

                    <VBox styleClass="auth-field-wrap">
                        <Label text="Username" styleClass="auth-label"/>
                        <TextField fx:id="usernameField"
                                   promptText="Choose a username"
                                   styleClass="auth-field">
                            <VBox.margin><Insets bottom="12"/></VBox.margin>
                        </TextField>

                        <Label text="Password" styleClass="auth-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <VBox.margin><Insets bottom="12"/></VBox.margin>
                            <StackPane HBox.hgrow="ALWAYS">
                                <PasswordField fx:id="passwordField"
                                               promptText="Create a password"
                                               styleClass="auth-field"/>
                                <TextField fx:id="visiblePasswordField"
                                           promptText="Create a password"
                                           styleClass="auth-field"/>
                            </StackPane>
                            <Button fx:id="passwordVisibilityButton"
                                    text="Show"
                                    onAction="#onTogglePasswordVisibility"
                                    styleClass="auth-visibility-button"/>
                        </HBox>

                        <Label text="Confirm Password" styleClass="auth-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <VBox.margin><Insets bottom="12"/></VBox.margin>
                            <StackPane HBox.hgrow="ALWAYS">
                                <PasswordField fx:id="confirmPasswordField"
                                               promptText="Confirm your password"
                                               onAction="#onCreateAccount"
                                               styleClass="auth-field"/>
                                <TextField fx:id="visibleConfirmPasswordField"
                                           promptText="Confirm your password"
                                           onAction="#onCreateAccount"
                                           styleClass="auth-field"/>
                            </StackPane>
                            <Button fx:id="confirmPasswordVisibilityButton"
                                    text="Show"
                                    onAction="#onToggleConfirmPasswordVisibility"
                                    styleClass="auth-visibility-button"/>
                        </HBox>
                    </VBox>

                    <Label fx:id="statusLabel" styleClass="auth-status" wrapText="true">
                        <VBox.margin><Insets top="4" bottom="12"/></VBox.margin>
                    </Label>

                    <Button text="Create Account" onAction="#onCreateAccount" styleClass="auth-submit"/>

                    <HBox alignment="CENTER" spacing="4">
                        <VBox.margin><Insets top="16"/></VBox.margin>
                        <Label text="Already have an account?" styleClass="auth-caption"/>
                        <Button text="Sign in" onAction="#onSignIn" styleClass="auth-link"/>
                    </HBox>

                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>
        </StackPane>
    </center>

</BorderPane>
